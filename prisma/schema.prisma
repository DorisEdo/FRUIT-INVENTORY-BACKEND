generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())

  fruits    Fruit[]
}

model Fruit {
  id            Int       @id @default(autoincrement())
  name          String
  description   String?
  price         Int
  stockQuantity Int
  supplier      String?
  expiryDate    DateTime?
  imageUrl      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  categoryId    Int
  category      Category  @relation(fields: [categoryId], references: [id])
}

enum Role {
  USER
  ADMIN
}